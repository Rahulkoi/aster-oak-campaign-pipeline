# Copy to .env and fill in. Never commit .env.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5434/campaigns

# Provider: "anthropic" or "openai" (any OpenAI-compatible endpoint).
LLM_PROVIDER=openai

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# OpenAI-compatible. Defaults below use Google Gemini's free tier
# (key from https://aistudio.google.com/apikey).
# For Groq: base_url=https://api.groq.com/openai/v1  model=llama-3.3-70b-versatile
# For OpenAI: base_url=https://api.openai.com/v1     model=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_MODEL=gemini-2.5-flash
